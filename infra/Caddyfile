# Edge reverse proxy.
#   SAIVA_SITE_ADDRESS=localhost              -> HTTPS on this machine (internal CA)
#   SAIVA_SITE_ADDRESS=https://192.168.1.50   -> LAN access (internal CA); `make deploy LAN=1`
#   SAIVA_SITE_ADDRESS=finance.example.com    -> public domain; set SAIVA_TLS=you@email.com
#
# SAIVA_SITE_HOST is the bare host (no scheme), used as `default_sni` so TLS still works when
# a client connects by IP — IP literals carry no SNI, so without this Caddy can't pick a cert.
# SAIVA_TLS is `internal` (Caddy's local CA, for localhost/LAN) or an email (Let's Encrypt).
{
	default_sni {$SAIVA_SITE_HOST:localhost}
	servers {
		protocols h1 h2
	}
}

{$SAIVA_SITE_ADDRESS:localhost} {
	encode gzip
	tls {$SAIVA_TLS:internal}

	# API
	handle /api/* {
		reverse_proxy api:8000
	}

	# Single-page app (static, with client-side routing fallback handled by the web service)
	handle {
		reverse_proxy web:8080
	}

	# Defense-in-depth headers (the API sets its own too). No HSTS here on purpose: with the
	# internal CA it would block the browser's "proceed" on the untrusted-cert warning.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
