# Edge reverse proxy with automatic HTTPS.
#   - SAIVA_SITE_ADDRESS=localhost            -> locally-trusted cert (dev)
#   - SAIVA_SITE_ADDRESS=finance.example.com  -> automatic Let's Encrypt certificate
#   - SAIVA_SITE_ADDRESS=https://192.168.1.50 -> LAN access; internal CA used automatically
#
# (Optional) for Let's Encrypt expiry-notice emails, add a global block above the site:
#   { email you@example.com }
{$SAIVA_SITE_ADDRESS:localhost} {
	encode gzip

	# Caddy uses its internal CA automatically for localhost and IP addresses. To force the
	# internal CA for a hostname without public DNS too, uncomment:
	# tls internal

	# API
	handle /api/* {
		reverse_proxy api:8000
	}

	# Single-page app (static, with client-side routing fallback handled by the web service)
	handle {
		reverse_proxy web:8080
	}

	# Defense-in-depth headers (Caddy adds these at the edge; the API sets its own too)
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
