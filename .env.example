# Saiva configuration — copy to `.env` and edit. NEVER commit `.env`.

# --- Required ---
# Long random string used to sign session cookies. Generate e.g. `openssl rand -hex 32`.
SECRET_KEY=change-me-to-a-long-random-string

# --- Site / TLS (Caddy) ---
# `localhost`  -> automatic, locally-trusted HTTPS for dev.
# `https://192.168.1.50` (a LAN IP) -> use a local CA (`tls internal`, see infra/Caddyfile).
# `finance.example.com` -> automatic Let's Encrypt certificate (set ACME_EMAIL too).
SAIVA_SITE_ADDRESS=localhost
ACME_EMAIL=

# --- Database ---
POSTGRES_USER=saiva
POSTGRES_PASSWORD=change-me-too
POSTGRES_DB=saiva

# --- Application ---
ENVIRONMENT=production
# Send the session cookie only over HTTPS. Keep `true` in production.
COOKIE_SECURE=true
# Extra comma-separated CORS origins. Usually empty in production (same-origin behind Caddy).
CORS_ORIGINS=
