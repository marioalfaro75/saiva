# Saiva configuration — copy to `.env` and edit. NEVER commit `.env`.

# --- Required ---
# Long random string used to sign session cookies. Generate e.g. `openssl rand -hex 32`.
SECRET_KEY=change-me-to-a-long-random-string

# --- Site / TLS (Caddy) ---
# `localhost`            -> HTTPS on this machine only (default).
# `https://192.168.1.50` -> reachable over your LAN (internal CA). `make deploy LAN=1`
#                           sets this and SAIVA_SITE_HOST to your detected IP automatically.
# `finance.example.com`  -> public domain; set SAIVA_TLS to your email for Let's Encrypt.
SAIVA_SITE_ADDRESS=localhost
# Bare host (no scheme), used as the TLS default_sni so connecting by IP works.
SAIVA_SITE_HOST=localhost
# `internal` (Caddy's local CA, for localhost/LAN) or your email address (Let's Encrypt).
SAIVA_TLS=internal

# --- Database ---
POSTGRES_USER=saiva
POSTGRES_PASSWORD=change-me-too
POSTGRES_DB=saiva

# --- Application ---
ENVIRONMENT=production
# Send the session cookie only over HTTPS. Keep `true` in production.
COOKIE_SECURE=true
# Extra comma-separated CORS origins. Usually empty in production (same-origin behind Caddy).
CORS_ORIGINS=

# --- Updates ---
# Which published image to run. `latest` tracks tagged releases (v*); `edge` tracks
# the newest green build of main (continuous). Or pin an immutable tag like
# `sha-1a2b3c4` to roll back. Used by docker-compose.prod.yml / `make pull`.
SAIVA_VERSION=latest
# Shared token between the app and the Watchtower updater; enables the in-app
# "Update now" button on pull-based deploys. `make deploy`/`make pull` generates one.
WATCHTOWER_TOKEN=
# Set to false to disable the app's GitHub update check (a public, data-free request).
UPDATE_CHECK_ENABLED=true

# --- Safety backups ---
# Before applying DB migrations on startup, write a compressed pg_dump to the
# db_backups volume (mounted at SAIVA_BACKUP_DIR). Set to 0 to skip. If the dump
# fails the container refuses to migrate, so an upgrade is always reversible.
SAIVA_BACKUP_BEFORE_MIGRATE=1
SAIVA_BACKUP_DIR=/backups

# --- Email & alerts (optional) ---
# SMTP is what powers alert emails and digests. Leave SMTP_HOST empty to keep all
# email off (in-app alerts still work). SMTP_FROM is required to enable sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true   # STARTTLS (port 587). Set SMTP_SSL=true instead for implicit TLS (465).
SMTP_SSL=false
# Token the scheduler passes to POST /api/notifications/run to generate alerts and
# send due digests, e.g. a cron line:
#   */30 * * * *  curl -fsS -X POST -H "X-Notify-Token: $TOKEN" https://<host>/api/notifications/run
NOTIFICATIONS_TOKEN=
